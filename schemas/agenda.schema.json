{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DuCUG agenda",
  "description": "Dagprogramma voor één DuCUG-editie (data/agenda/ducug-NN.json).",
  "type": "object",
  "required": ["sessions"],
  "properties": {
    "$schema": { "type": "string" },
    "sessions": {
      "type": "array",
      "description": "Sessies in chronologische volgorde.",
      "items": {
        "type": "object",
        "required": ["title"],
        "additionalProperties": false,
        "properties": {
          "start": {
            "type": "string",
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
            "description": "Starttijd, 24-uurs HH:MM (bijv. \"09:10\")."
          },
          "end": {
            "type": "string",
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$",
            "description": "Eindtijd, 24-uurs HH:MM."
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Sessietitel."
          },
          "speakers": {
            "type": "string",
            "description": "Spreker(s), vrij tekstveld (bijv. \"Jan Tytgat\" of \"Steven Beuving, Patrick Kaak (Ivanti)\")."
          },
          "type": {
            "type": "string",
            "enum": ["talk", "sponsor", "break", "org", "social"],
            "default": "talk",
            "description": "talk = sessie · sponsor = sponsorsessie (Sponsor-tag) · break = pauze · org = organisatie (opening/afsluiting) · social = borrel/diner."
          },
          "featured": {
            "type": "boolean",
            "description": "true = Keynote-badge + highlight."
          }
        }
      }
    }
  }
}
